CompileFlags:
  Compiler: cl
  Add:
    # ── Target & standard ────────────────────────────────────────────────
    - --target=x86_64-pc-windows-msvc
    - /std:c++latest
    - /EHsc
    - -fdelayed-template-parsing
    - /utf-8

    # ── Preprocessor defines (matching Release|x64 vcxproj) ──────────
    - -DNDEBUG
    - -D_CONSOLE
    - -DFMT_HEADER_ONLY
    - -DWIN32_LEAN_AND_MEAN
    - -DNOMINMAX
    - -DUNICODE
    - -D_UNICODE

    # ── MSVC STL & CRT headers (system headers, <> only is fine) ─────
    - -imsvc
    - "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/14.44.35207/include"

    # ── Windows SDK (ucrt, um, shared — also system headers) ─────────
    - -imsvc
    - "C:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/ucrt"
    - -imsvc
    - "C:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/um"
    - -imsvc
    - "C:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/shared"

    # ── VCPKG installed packages — use -I so quoted includes resolve ──
    - -I
    - "C:/Users/Elytras/Desktop/cppstuff/vcwhatever/vcpkg/installed/x64-windows-static/include"

    # ── Project-local includes (DrgMods directory) ───────────────────
    - -I
    - DrgMods

    # ── Suppress noisy MSVC-compat warnings in clangd ────────────────
    - -Wno-pragma-pack
    - -Wno-microsoft-include
    - -Wno-microsoft-enum-value
    - -Wno-invalid-token-paste
    - -Wno-unknown-pragmas
    - -Wno-ignored-pragma-intrinsic
    - -Wno-ignored-attributes
    - -Wno-microsoft-unqualified-friend
    - -Wno-nonportable-include-path
    - -Wno-c++11-narrowing
    - -Wno-typename-missing

Diagnostics:
  Suppress:
    - pp_file_not_found
    - warn_expected_qualified_after_typename
    - bad_cxx_cast_unrelated_class
    - field_incomplete_or_sizeless
  UnusedIncludes: None         # don't flag unused includes — MSVC doesn't

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

Hover:
  ShowAKA: true
